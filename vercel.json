{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps && npm install -g prisma && npx prisma generate && npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_VERSION": "20.x"
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "regions": ["iad1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    }
  },
  "public": true
}
