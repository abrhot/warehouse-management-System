// tsconfig.script.json

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./dist"
  },
  // THIS IS THE FIX: We are now including all TypeScript files
  // so the compiler can find the Prisma Client module.
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}