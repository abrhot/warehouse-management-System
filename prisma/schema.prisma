// This is your Prisma schema file.
// Remember to run `npx prisma migrate dev` and `npx prisma generate` after changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USERS & LOGS /////////////////////////////////////////////////////////////////
model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  // Relations
  requests  StockRequest[] @relation("RequestedBy")
  approvals StockRequest[] @relation("ApprovedBy")
  auditLogs AuditLog[]
}

model AuditLog {
  id     String     @id @default(uuid())
  action ActionType

  details   String
  createdAt DateTime @default(now())

  // Relations
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  stockItem StockItem? @relation(fields: [stockItemId], references: [id])

  productId   String?
  stockItemId String?
}

// WAREHOUSE CORE MODELS /////////////////////////////////////////////////////////
model Product {
  id           String     @id @default(uuid())
  sku          String     @unique
  name         String
  location     String?
  reorderLevel Int        @default(10)
  weight       Float?
  dimensions   String?
  costPrice    Decimal    @db.Decimal(10, 2)
  sellingPrice Decimal?   @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  quantity     Int        @default(0)
  auditLogs    AuditLog[]

  // Relations
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  stockItems StockItem[]

  @@unique([name, categoryId])
  @@index([name])
}

model StockItem {
  id           String     @id @default(uuid())
  serialNumber String     @unique
  status       ItemStatus @default(IN_STOCK)
  location     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt

  // Relations
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // This is the relation field that points back to StockRequest.
  // We do not define the foreign key or references here.
  stockRequest StockRequest?
  auditLogS    AuditLog[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  contactInfo String?
  products    Product[]
}

// STOCK RECORDS & REQUESTS //////////////////////////////////////////////////////
model StockRequest {
  id        String        @id @default(uuid())
  type      StockType
  status    RequestStatus @default(PENDING)
  notes     String?
  reason    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime?     @updatedAt

  // Relations: One StockRequest links to one StockItem.
  // The foreign key (stockItemId) and the relation definition are correctly placed here.
  stockItemId String?    @unique
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  requestedBy String @map("requested_by")
  requester   User   @relation("RequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)

  approvedBy String? @map("approved_by")
  approver   User?   @relation("ApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
}

// ENUMS ////////////////////////////////////////////////////////////////////////
enum Role {
  ADMIN
  USER
}

enum StockType {
  IN
  OUT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ItemStatus {
  IN_STOCK
  RESERVED
  SHIPPED
  DAMAGED
}

enum ActionType {
  USER_LOGIN
  USER_CREATED
  PRODUCT_CREATED
  STOCK_REQUEST_CREATED
  STOCK_REQUEST_APPROVED
  STOCK_REQUEST_REJECTED
}
