generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                          Int            @id @default(autoincrement())
  name                                        String?
  email                                       String?        @unique
  password                                    String?
  role                                        Role           @default(USER)
  createdAt                                   DateTime       @default(now())
  emailVerified                               DateTime?
  image                                       String?
  accounts                                    Account[]
  auditLogs                                   AuditLog[]
  sessions                                    Session[]
  StockRequest_StockRequest_approvedByToUser  StockRequest[] @relation("StockRequest_approvedByToUser")
  StockRequest_StockRequest_requestedByToUser StockRequest[] @relation("StockRequest_requestedByToUser")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id            String         @id @default(cuid())
  name          String
  quantity      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  costPrice     Decimal        @default(0)
  location      String?
  reorderLevel  Int            @default(10)
  sellingPrice  Decimal?
  sku           String         @unique
  categoryId    Int
  dimensions    String?
  supplierId    Int?
  weight        Float?
  category      Category       @relation(fields: [categoryId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  stockRequests StockRequest[]

  @@unique([name, categoryId])
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  contactInfo String?
  products    Product[]
}

model StockRequest {
  id                                  String        @id @default(cuid())
  type                                StockType
  quantity                            Int
  status                              RequestStatus @default(PENDING)
  createdAt                           DateTime      @default(now())
  updatedAt                           DateTime      @updatedAt
  productId                           String
  requestedBy                         Int
  approvedBy                          Int?
  notes                               String?
  reason                              String?
  User_StockRequest_approvedByToUser  User?         @relation("StockRequest_approvedByToUser", fields: [approvedBy], references: [id])
  product                             Product       @relation(fields: [productId], references: [id])
  User_StockRequest_requestedByToUser User          @relation("StockRequest_requestedByToUser", fields: [requestedBy], references: [id])
}

model AuditLog {
  id        Int        @id @default(autoincrement())
  action    ActionType
  details   String
  createdAt DateTime   @default(now())
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}

enum StockType {
  IN
  OUT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionType {
  USER_LOGIN
  USER_CREATED
  PRODUCT_CREATED
  STOCK_REQUEST_CREATED
  STOCK_REQUEST_APPROVED
  STOCK_REQUEST_REJECTED
}
