// This is your Prisma schema file.
// Remember to run `npx prisma migrate dev` and `npx prisma generate` after changes.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USERS & LOGS /////////////////////////////////////////////////////////////////
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // Relations
  requests  StockRequest[] @relation("RequestedBy")
  approvals StockRequest[] @relation("ApprovedBy")
  auditLogs AuditLog[]
}

model AuditLog {
  id        String     @id @default(uuid())
  action    ActionType
  details   String
  createdAt DateTime   @default(now())

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
}

// WAREHOUSE CORE MODELS /////////////////////////////////////////////////////////
model Product {
  id           String   @id @default(uuid())
  name         String
  location     String?
  reorderLevel Int      @default(10)
  weight       Float?
  dimensions   String?
  costPrice    Decimal  @default(0) @db.Decimal(10, 2)
  sellingPrice Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  categoryId Int
  category   Category    @relation(fields: [categoryId], references: [id])
  supplierId Int?
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  stockItems StockItem[] // One product has many stock items

  @@unique([name, categoryId])
}

// NEW MODEL: This is the core of the new system
model StockItem {
  id           String     @id @default(uuid())
  serialNumber String     @unique // The new unique identifier
  status       ItemStatus @default(IN_STOCK)
  location     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  productId    String
  product      Product        @relation(fields: [productId], references: [id])
  stockRequest StockRequest[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  contactInfo String?
  products    Product[]
}

// STOCK RECORDS & REQUESTS //////////////////////////////////////////////////////
model StockRequest {
  id        String        @id @default(uuid())
  type      StockType
  status    RequestStatus @default(PENDING)
  notes     String?
  reason    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  requestedBy String @map("requested_by")
  requester   User   @relation("RequestedBy", fields: [requestedBy], references: [id])

  approvedBy String? @map("approved_by")
  approver   User?   @relation("ApprovedBy", fields: [approvedBy], references: [id])
}

// ENUMS ////////////////////////////////////////////////////////////////////////
enum Role {
  ADMIN
  USER
}

enum StockType {
  IN
  OUT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// NEW ENUM: To track the status of each individual item
enum ItemStatus {
  IN_STOCK
  RESERVED
  SHIPPED
  DAMAGED
}

enum ActionType {
  USER_LOGIN
  USER_CREATED
  PRODUCT_CREATED
  STOCK_REQUEST_CREATED
  STOCK_REQUEST_APPROVED
  STOCK_REQUEST_REJECTED
}
