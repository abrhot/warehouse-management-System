generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- AUTHENTICATION MODELS ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]

  requestsMade      StockRequest[] @relation("RequestedBy")
  requestsProcessed StockRequest[] @relation("ApprovedBy")
  auditLogs         AuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- WAREHOUSE CORE MODELS ---
model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  description  String?
  quantity     Int      @default(0) // Single source of truth for stock level
  reorderLevel Int      @default(10)
  costPrice    Decimal  @default(0)
  sellingPrice Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockRequests   StockRequest[]
  inventoryLedger LedgerEntry[]

  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([name, categoryId])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
}

model Supplier {
  id          String    @id @default(cuid())
  name        String    @unique
  contactInfo String?
  products    Product[]
}

model StockRequest {
  id        String        @id @default(cuid())
  type      StockType
  quantity  Int
  status    RequestStatus @default(PENDING)
  notes     String?
  reason    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id])

  requestedById String
  requester     User   @relation("RequestedBy", fields: [requestedById], references: [id])

  approvedById String?
  approver     User?   @relation("ApprovedBy", fields: [approvedById], references: [id])

  ledgerEntry LedgerEntry? // A request can have one ledger entry if approved
}

// --- LOGGING ---
model AuditLog {
  id        String     @id @default(cuid())
  action    ActionType
  details   String
  createdAt DateTime   @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// THIS IS THE NEW IMMUTABLE LEDGER
model LedgerEntry {
  id          String   @id @default(cuid())
  change      Int // The actual change (+ for IN, - for OUT)
  newQuantity Int // The quantity of the product *after* the change
  createdAt   DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // A ledger entry is created by exactly one stock request
  stockRequestId String       @unique
  stockRequest   StockRequest @relation(fields: [stockRequestId], references: [id])
}

// --- ENUMS ---
enum Role {
  ADMIN
  USER
}

enum StockType {
  IN
  OUT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionType {
  USER_LOGIN
  USER_CREATED
  PRODUCT_CREATED
  STOCK_REQUEST_CREATED
  STOCK_REQUEST_APPROVED
  STOCK_REQUEST_REJECTED
}
